{
  "info": {
    "_postman_id": "8d5752df-9b57-4de9-a28a-1f456f2a3d0f",
    "name": "Teacher Administration API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Teacher Administration API endpoints implemented in Story 002."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('health payload shape is correct', function () {",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.database).to.eql('up');",
                  "  pm.expect(body.timestamp).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Teacher Student",
      "item": [
        {
          "name": "Register Students",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 204', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacher\": \"{{teacherEmail}}\",\n  \"students\": [\n    \"{{studentOneEmail}}\",\n    \"{{studentTwoEmail}}\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "Register Validation Error",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('register validation message is correct', function () {",
                  "  pm.expect(body.message).to.eql('Validation errors');",
                  "  pm.expect(body.errors.teacher).to.include('Teacher is missing');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
